# Copy this file to .dev.vars and fill in your actual values.
# .dev.vars is used by Wrangler for local development secrets — never commit it.

NODE_ENV=development

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# HS256 signing key — must be at least 32 characters
JWT_SECRET=change-me-to-a-secure-random-string-of-at-least-32-chars
