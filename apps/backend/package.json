    "hono": "^4.7.0",
    "jose": "^5.9.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@eslint/js": "^9.0.0",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.0.0"
